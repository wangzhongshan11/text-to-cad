<?xml version="1.0" encoding="utf-8"?>
<robot name="4DOF_RobotArm">

  <!-- ===== BASE LINK (ground) ===== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.09" length="0.027"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.09" length="0.027"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.0135" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <!-- ===== J1 (base rotation, +Z) ===== -->
  <joint name="joint_j1" type="revolute">
    <parent link="base_link"/>
    <child link="link_j1"/>
    <origin xyz="0 0 0.0395" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-3.1416" upper="3.1416" velocity="3.14"/>
  </joint>
  <link name="link_j1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.038" length="0.025"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.038" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <!-- ===== Shoulder Link (fastened to J1 output) ===== -->
  <joint name="joint_shoulder" type="fixed">
    <parent link="link_j1"/>
    <child link="link_shoulder"/>
    <origin xyz="0 0 0.0425" rpy="0 0 0"/>
  </joint>
  <link name="link_shoulder">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.048 0.042 0.06"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.048 0.042 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ===== J2 (shoulder pitch, +Y) ===== -->
  <joint name="joint_j2" type="revolute">
    <parent link="link_shoulder"/>
    <child link="link_j2"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="80" lower="-2.3562" upper="1.0472" velocity="2.0"/>
  </joint>
  <link name="link_j2">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.046"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.046"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.0015" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <!-- ===== Upper Arm Link (fastened to J2 output) ===== -->
  <joint name="joint_upper_arm" type="fixed">
    <parent link="link_j2"/>
    <child link="link_upper_arm"/>
    <origin xyz="0 0.103 0" rpy="1.5708 0 0"/>
  </joint>
  <link name="link_upper_arm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.038 0.034 0.16"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.038 0.034 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ===== J3 (elbow pitch, +Y) ===== -->
  <joint name="joint_j3" type="revolute">
    <parent link="link_upper_arm"/>
    <child link="link_j3"/>
    <origin xyz="0 0 0.106" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="60" lower="-2.618" upper="2.618" velocity="2.5"/>
  </joint>
  <link name="link_j3">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.04"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.6"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0015"/>
    </inertial>
  </link>

  <!-- ===== Forearm Link (fastened to J3 output) ===== -->
  <joint name="joint_forearm" type="fixed">
    <parent link="link_j3"/>
    <child link="link_forearm"/>
    <origin xyz="0 0.085 0" rpy="1.5708 0 0"/>
  </joint>
  <link name="link_forearm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.032 0.028 0.13"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.032 0.028 0.13"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.0015" iyz="0" izz="0.0008"/>
    </inertial>
  </link>

  <!-- ===== J4 (wrist roll, +X) ===== -->
  <joint name="joint_j4" type="revolute">
    <parent link="link_forearm"/>
    <child link="link_j4"/>
    <origin xyz="0 0 0.0825" rpy="0 1.5708 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="40" lower="-3.1416" upper="3.1416" velocity="3.14"/>
  </joint>
  <link name="link_j4">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.035"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.035"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- ===== Wrist Housing (fastened to J4 output) ===== -->
  <joint name="joint_wrist" type="fixed">
    <parent link="link_j4"/>
    <child link="link_wrist"/>
    <origin xyz="0.0315 0 0" rpy="0 0 0"/>
  </joint>
  <link name="link_wrist">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.024" length="0.028"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.024" length="0.028"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- ===== Gripper Base (fastened to wrist) ===== -->
  <joint name="joint_gripper_base" type="fixed">
    <parent link="link_wrist"/>
    <child link="link_gripper_base"/>
    <origin xyz="0.029 0 0" rpy="0 0 0"/>
  </joint>
  <link name="link_gripper_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.036 0.03 0.014"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.036 0.03 0.014"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00015"/>
    </inertial>
  </link>

  <!-- ===== Left Finger (fastened to gripper base) ===== -->
  <joint name="joint_left_finger" type="fixed">
    <parent link="link_gripper_base"/>
    <child link="link_left_finger"/>
    <origin xyz="0.026 0.009 0" rpy="0 0 0"/>
  </joint>
  <link name="link_left_finger">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.022 0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.022 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="5e-06" iyz="0" izz="1e-05"/>
    </inertial>
  </link>

  <!-- ===== Right Finger (fastened to gripper base) ===== -->
  <joint name="joint_right_finger" type="fixed">
    <parent link="link_gripper_base"/>
    <child link="link_right_finger"/>
    <origin xyz="0.026 -0.009 0" rpy="0 0 0"/>
  </joint>
  <link name="link_right_finger">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.022 0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.022 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="5e-06" iyz="0" izz="1e-05"/>
    </inertial>
  </link>

</robot>
